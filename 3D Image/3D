/** Tiny rendered keyline of one type for the candidate row. */
function CandidateThumb({ contentType, grain }: { contentType: string; grain: string }) {
  const { data: session } = useSession()
  const refDims: Dims = useMemo(
    () => ({ L: 200, W: 100, H: 150, OF: 30, PF: 12, BF: 30, FH: 25, TH: 20 }),
    []
  )
  const [rows, setRows] = useState<KeylineRow[]>([])
  useEffect(() => {
    if (!session) return
    let cancelled = false
    PlanWindowAPI.getKeylineCoordinates(contentType, grain, session).then(resp => {
      if (cancelled) return
      if (resp.success && Array.isArray(resp.data)) setRows(resp.data as KeylineRow[])
    }).catch(() => { /* leave empty */ })
    return () => { cancelled = true }
  }, [session, contentType, grain])

  const segments = useMemo(() => {
    try { return rowsToSegments(rows, refDims) } catch { return [] as Segment[] }
  }, [rows, refDims])

  const bbox = useMemo(() => {
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity
    for (const s of segments) {
      minX = Math.min(minX, s.x1, s.x2); minY = Math.min(minY, s.y1, s.y2)
      maxX = Math.max(maxX, s.x1, s.x2); maxY = Math.max(maxY, s.y1, s.y2)
    }
    if (!isFinite(minX)) return null
    const pad = 8
    return { minX: minX - pad, minY: minY - pad, w: maxX - minX + 2 * pad, h: maxY - minY + 2 * pad }
  }, [segments])

  if (!bbox) {
    return <div className="h-14 flex items-center justify-center text-[8px] text-[rgb(var(--fg-muted))]">·</div>
  }
  return (
    <svg viewBox={`${bbox.minX} ${bbox.minY} ${bbox.w} ${bbox.h}`} preserveAspectRatio="xMidYMid meet" className="w-full h-14">
      {segments.map((s, i) => {
        const isCurve = s.shape === 'Curve'
        const isCircle = s.shape === 'Circle'
        const stroke = isCurve || isCircle ? '#dc2626' : (s.isDashed ? '#2563eb' : '#111')
        const dash = s.isDashed ? '2,2' : undefined
        if (isCurve) {
          return <path key={i} d={`M ${s.x1} ${s.y1} Q ${s.x1} ${s.y2} ${s.x2} ${s.y2}`} stroke={stroke} strokeWidth={1} fill="none" strokeDasharray={dash} />
        }
        if (isCircle) {
          const r = Math.sqrt((s.x2 - s.x1) ** 2 + (s.y2 - s.y1) ** 2) / 2
          return <path key={i} d={`M ${s.x1} ${s.y1} A ${r} ${r} 0 1 1 ${s.x2} ${s.y2}`} stroke={stroke} strokeWidth={1} fill="none" strokeDasharray={dash} />
        }
        return <line key={i} x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke={stroke} strokeWidth={1} strokeDasharray={dash} />
      })}
    </svg>
  )
}

/**
 * Renders a compact 2D keyline of a given content type so the user can
 * visually verify the LLM's content-type pick against their uploaded image.
 * Fetches keyline rows fresh per type via the same API the main viewer uses.
 */
function KeylineReferencePreview({
  contentType, grain, dims,
}: {
  contentType: string
  grain: string
  dims: Dims
}) {
  const { data: session } = useSession()
  const [rows, setRows] = useState<KeylineRow[]>([])
  const [state, setState] = useState<'idle' | 'loading' | 'ok' | 'error'>('idle')

  useEffect(() => {
    if (!session) return
    let cancelled = false
    setState('loading')
      ; (async () => {
        try {
          const resp = await PlanWindowAPI.getKeylineCoordinates(contentType, grain, session)
          if (cancelled) return
          if (resp.success && Array.isArray(resp.data) && resp.data.length > 0) {
            setRows(resp.data as KeylineRow[])
            setState('ok')
          } else {
            setRows([])
            setState('error')
          }
        } catch {
          if (cancelled) return
          setRows([])
          setState('error')
        }
      })()
    return () => { cancelled = true }
  }, [session, contentType, grain])

  const segments = useMemo(() => {
    try { return rowsToSegments(rows, dims) } catch { return [] as Segment[] }
  }, [rows, dims])

  const bbox = useMemo(() => {
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity
    for (const s of segments) {
      minX = Math.min(minX, s.x1, s.x2)
      minY = Math.min(minY, s.y1, s.y2)
      maxX = Math.max(maxX, s.x1, s.x2)
      maxY = Math.max(maxY, s.y1, s.y2)
    }
    if (!isFinite(minX)) return null
    const pad = 10
    return { minX: minX - pad, minY: minY - pad, w: maxX - minX + 2 * pad, h: maxY - minY + 2 * pad }
  }, [segments])

  return (
    <div className="rounded border border-[rgb(var(--bd-default))] bg-[rgb(var(--bg-surface))] overflow-hidden">
      <div className="px-2 py-1 text-[10px] font-medium text-[rgb(var(--fg-muted))] border-b border-[rgb(var(--bd-default))]">
        Reference keyline · {contentType}
      </div>
      <div className="h-32 flex items-center justify-center">
        {state === 'loading' && (
          <span className="text-[10px] text-[rgb(var(--fg-muted))]">Loading…</span>
        )}
        {state === 'error' && (
          <span className="text-[10px] text-[rgb(var(--color-error))]">No keyline data for this type</span>
        )}
        {state === 'ok' && bbox && (
          <svg
            viewBox={`${bbox.minX} ${bbox.minY} ${bbox.w} ${bbox.h}`}
            preserveAspectRatio="xMidYMid meet"
            className="w-full h-full"
          >
            {segments.map((s, i) => {
              const isCurve = s.shape === 'Curve'
              const isCircle = s.shape === 'Circle'
              const stroke = isCurve || isCircle ? '#dc2626' : (s.isDashed ? '#2563eb' : '#111')
              const strokeDasharray = s.isDashed ? '1.5,1.5' : undefined
              if (isCurve) {
                return <path key={i} d={`M ${s.x1} ${s.y1} Q ${s.x1} ${s.y2} ${s.x2} ${s.y2}`}
                  stroke={stroke} strokeWidth={0.6} fill="none" strokeDasharray={strokeDasharray} />
              }
              if (isCircle) {
                const r = Math.sqrt((s.x2 - s.x1) ** 2 + (s.y2 - s.y1) ** 2) / 2
                return <path key={i} d={`M ${s.x1} ${s.y1} A ${r} ${r} 0 1 1 ${s.x2} ${s.y2}`}
                  stroke={stroke} strokeWidth={0.6} fill="none" strokeDasharray={strokeDasharray} />
              }
              return <line key={i} x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2}
                stroke={stroke} strokeWidth={0.6} strokeDasharray={strokeDasharray} />
            })}
          </svg>
        )}
      </div>
    </div>
  )
}

function ImageDropzone({
  file, preview, onPick,
}: {
  file: File | null
  preview: string | null
  onPick: (f: File | null) => void
}) {
  const inputRef = useRef<HTMLInputElement>(null)
  const [dragging, setDragging] = useState(false)

  const onDrop = (e: React.DragEvent) => {
    e.preventDefault()
    setDragging(false)
    const f = e.dataTransfer.files?.[0]
    if (f && f.type.startsWith('image/')) onPick(f)
  }

  if (preview) {
    return (
      <div className="relative rounded border border-[rgb(var(--bd-default))] overflow-hidden bg-[rgb(var(--bg-subtle))]">
        <img src={preview} alt="dieline" className="w-full h-32 object-contain" />
        <button
          type="button"
          onClick={() => onPick(null)}
          className="absolute top-1 right-1 p-1 rounded bg-[rgb(var(--bg-surface))] border border-[rgb(var(--bd-default))] hover:bg-[rgb(var(--bg-subtle))]"
          aria-label="Remove image"
        >
          <X className="w-3 h-3" />
        </button>
        <div className="px-2 py-1 text-[10px] text-[rgb(var(--fg-muted))] truncate border-t border-[rgb(var(--bd-default))]">
          {file?.name}
        </div>
      </div>
    )
  }

  return (
    <div
      onClick={() => inputRef.current?.click()}
      onDragOver={e => { e.preventDefault(); setDragging(true) }}
      onDragLeave={() => setDragging(false)}
      onDrop={onDrop}
      className={`flex flex-col items-center justify-center gap-1 px-3 py-4 rounded border-2 border-dashed cursor-pointer transition-colors ${dragging
          ? 'border-[rgb(var(--color-primary))] bg-[rgb(var(--bg-subtle))]'
          : 'border-[rgb(var(--bd-default))] hover:bg-[rgb(var(--bg-subtle))]'
        }`}
    >
      <Upload className="w-4 h-4 text-[rgb(var(--fg-muted))]" />
      <div className="text-[11px] text-[rgb(var(--fg-muted))] text-center">
        Drop dieline image or click to browse
      </div>
      <input
        ref={inputRef}
        type="file"
        accept="image/*"
        className="hidden"
        onChange={e => onPick(e.target.files?.[0] ?? null)}
      />
    </div>
  )
}

