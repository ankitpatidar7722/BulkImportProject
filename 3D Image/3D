// ─── 2D Keyline Debug Canvas ─────────────────────────────────
// Renders all evaluated line segments + colored panel overlays, so we can
// SEE which regions are detected vs missed against the actual keyline.

const PANEL_COLORS = [
  'rgba(239, 68, 68, 0.25)',   // red
  'rgba(59, 130, 246, 0.25)',  // blue
  'rgba(34, 197, 94, 0.25)',   // green
  'rgba(234, 179, 8, 0.25)',   // yellow
  'rgba(168, 85, 247, 0.25)',  // purple
  'rgba(236, 72, 153, 0.25)',  // pink
  'rgba(20, 184, 166, 0.25)',  // teal
  'rgba(251, 146, 60, 0.25)',  // orange
  'rgba(99, 102, 241, 0.25)',  // indigo
  'rgba(132, 204, 22, 0.25)',  // lime
  'rgba(244, 114, 182, 0.25)', // rose
  'rgba(14, 165, 233, 0.25)',  // sky
  'rgba(217, 70, 239, 0.25)',  // fuchsia
]

function KeylineDebugCanvas({
  rows, dims, panels,
}: { rows: KeylineRow[]; dims: Dims; panels: Panel[] }) {
  const segments = useMemo(() => {
    try { return rowsToSegments(rows, dims) } catch { return [] as Segment[] }
  }, [rows, dims])

  // Compute bounding box from all segments + panels
  const bbox = useMemo(() => {
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity
    for (const s of segments) {
      minX = Math.min(minX, s.x1, s.x2)
      minY = Math.min(minY, s.y1, s.y2)
      maxX = Math.max(maxX, s.x1, s.x2)
      maxY = Math.max(maxY, s.y1, s.y2)
    }
    for (const p of panels) {
      minX = Math.min(minX, p.rect.x)
      minY = Math.min(minY, p.rect.y)
      maxX = Math.max(maxX, p.rect.x + p.rect.w)
      maxY = Math.max(maxY, p.rect.y + p.rect.h)
    }
    if (!isFinite(minX)) return { minX: 0, minY: 0, maxX: 100, maxY: 100 }
    const pad = 20
    return { minX: minX - pad, minY: minY - pad, maxX: maxX + pad, maxY: maxY + pad }
  }, [segments, panels])

  if (segments.length === 0) {
    return (
      <div className="h-full flex items-center justify-center text-[rgb(var(--fg-muted))] text-sm">
        No keyline data — waiting for API
      </div>
    )
  }

  const vbW = bbox.maxX - bbox.minX
  const vbH = bbox.maxY - bbox.minY

  return (
    <div className="h-full w-full flex flex-col">
      <div className="px-3 py-1.5 text-[11px] text-[rgb(var(--fg-muted))] border-b border-[rgb(var(--bd-default))] bg-[rgb(var(--bg-subtle))]">
        2D keyline · solid=cut · dashed=fold · red=curve · color overlays = detected panels
      </div>
      <div className="flex-1 min-h-0">
        <svg
          viewBox={`${bbox.minX} ${bbox.minY} ${vbW} ${vbH}`}
          preserveAspectRatio="xMidYMid meet"
          style={{ width: '100%', height: '100%' }}
        >
          {/* Panel overlays first (under the lines) */}
          {panels.map((p, i) => {
            const color = PANEL_COLORS[i % PANEL_COLORS.length]
            const stroke = color.replace('0.25', '0.9')
            return (
              <g key={p.id}>
                <rect
                  x={p.rect.x} y={p.rect.y}
                  width={p.rect.w} height={p.rect.h}
                  fill={color}
                  stroke={stroke}
                  strokeWidth={0.4}
                />
                <text
                  x={p.rect.x + p.rect.w / 2}
                  y={p.rect.y + p.rect.h / 2}
                  fontSize={Math.max(4, Math.min(p.rect.w, p.rect.h) / 6)}
                  fill="#000"
                  textAnchor="middle"
                  dominantBaseline="middle"
                  fontWeight={600}
                >
                  {p.id}
                </text>
              </g>
            )
          })}
          {/* Reference grid lines at the named X/Y bands */}
          {(() => {
            const xs = [
              { val: 0, label: '0' },
              { val: dims.PF, label: 'PF' },
              { val: dims.PF + dims.L, label: 'PF+L' },
              { val: dims.PF + dims.L + dims.W, label: 'PF+L+W' },
              { val: dims.PF + dims.L + dims.W + dims.L, label: 'PF+L+W+L' },
              { val: 2 * dims.W + 2 * dims.L + dims.PF, label: '2W+2L+PF' },
            ]
            const ys = [
              { val: 0, label: '0' },
              { val: dims.OF, label: 'OF' },
              { val: dims.OF + dims.W, label: 'OF+W' },
              { val: dims.OF + dims.W + dims.H, label: 'OF+W+H' },
              { val: dims.OF + dims.W + dims.H + dims.W, label: 'OF+W+H+W' },
              { val: 2 * (dims.OF + dims.W) + dims.H, label: '2(OF+W)+H' },
            ]
            return (
              <g opacity={0.35}>
                {xs.map(x => (
                  <g key={`x-${x.label}`}>
                    <line x1={x.val} y1={bbox.minY} x2={x.val} y2={bbox.maxY} stroke="#9ca3af" strokeWidth={0.2} strokeDasharray="0.5,0.5" />
                    <text x={x.val} y={bbox.minY + 6} fontSize={3} fill="#6b7280" textAnchor="middle">{x.label}</text>
                  </g>
                ))}
                {ys.map(y => (
                  <g key={`y-${y.label}`}>
                    <line x1={bbox.minX} y1={y.val} x2={bbox.maxX} y2={y.val} stroke="#9ca3af" strokeWidth={0.2} strokeDasharray="0.5,0.5" />
                    <text x={bbox.minX + 4} y={y.val + 1.5} fontSize={3} fill="#6b7280">{y.label}</text>
                  </g>
                ))}
              </g>
            )
          })()}
          {/* Lines on top */}
          {segments.map((s, i) => {
            const isCurve = s.shape === 'Curve'
            const isCircle = s.shape === 'Circle'
            const stroke = isCurve || isCircle ? '#dc2626' : (s.isDashed ? '#2563eb' : '#111')
            const strokeDasharray = s.isDashed ? '1,1' : undefined
            if (isCurve) {
              // Match the legacy drawCurveNSolid path: M x1 y1 Q x1 y2 x2 y2
              const d = `M ${s.x1} ${s.y1} Q ${s.x1} ${s.y2} ${s.x2} ${s.y2}`
              return (
                <path key={i} d={d} stroke={stroke} strokeWidth={0.5} fill="none" strokeDasharray={strokeDasharray} />
              )
            }
            if (isCircle) {
              const r = Math.sqrt((s.x2 - s.x1) ** 2 + (s.y2 - s.y1) ** 2) / 2
              const d = `M ${s.x1} ${s.y1} A ${r} ${r} 0 1 1 ${s.x2} ${s.y2}`
              return (
                <path key={i} d={d} stroke={stroke} strokeWidth={0.5} fill="none" strokeDasharray={strokeDasharray} />
              )
            }
            return (
              <line key={i} x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke={stroke} strokeWidth={0.5} strokeDasharray={strokeDasharray} />
            )
          })}
        </svg>
      </div>
    </div>
  )
}

